    <style>
        /* Premium Background with subtle technical dot-grid */
        body { 
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif; 
            background-color: #f8fafc;
            background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
            background-size: 20px 20px;
            color: #0f172a; 
            -webkit-font-smoothing: antialiased;
        }
        
        /* Glassmorphism utilities */
        .glass-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05);
        }

        .chart-container { position: relative; width: 100%; max-width: 800px; margin-left: auto; margin-right: auto; height: 350px; max-height: 400px; }
        
        /* Navigation Buttons */
        .nav-btn { position: relative; overflow: hidden; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .nav-btn::before { content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%; background: #0ea5e9; transform: scaleY(0); transition: transform 0.3s ease; transform-origin: left; }
        .nav-btn.active { background: rgba(14, 165, 233, 0.08); color: #0369a1; font-weight: 600; }
        .nav-btn.active::before { transform: scaleY(1); }
        .nav-btn:active { transform: scale(0.97); }

        /* Architecture Nodes */
        .arch-node { transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1); }
        .arch-node:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 15px 30px -5px rgba(14, 165, 233, 0.15); cursor: pointer; border-color: #38bdf8; background: rgba(255,255,255,0.95); }
        .arch-node:active { transform: scale(0.95); } 
        .arch-active { border-color: #0ea5e9; background: #f0f9ff; box-shadow: inset 0 0 0 1px #0ea5e9; }
        
        /* Animations */
        @keyframes fadeSlideUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeSlideUp 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="flex flex-col md:flex-row min-h-screen">

