            <button onclick="triggerHaptic(15); showSection('philosophy', this)" class="nav-btn text-left px-5 py-3.5 rounded-xl hover:bg-slate-100/50 text-slate-600">Design Philosophy</button>
            <div class="h-px w-full bg-slate-200 my-2"></div>
            <button onclick="triggerHaptic(20); showSection('simulation', this)" class="nav-btn text-left px-5 py-3.5 rounded-xl hover:bg-emerald-50/50 text-emerald-600 font-semibold flex items-center gap-2 group">
                <span class="text-emerald-500 group-hover:animate-pulse">▶</span> Live Simulation
